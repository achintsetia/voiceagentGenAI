rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can read and write only their own conversation sessions.
    // Path: /conversations/{userEmail}/sessions/{sessionId}
    match /conversations/{userEmail}/sessions/{sessionId} {
      allow read, write: if request.auth != null
                         && request.auth.token.email == userEmail;
    }

    // Each user can read and write only their own profile document (agent config, etc.).
    // Path: /users/{uid}
    match /users/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // Each user can read and manage only their own todo items.
    // Path: /todos/{userEmail}/items/{itemId}
    // Write (create/update for status changes) is allowed; delete is allowed for cleanup.
    match /todos/{userEmail}/items/{itemId} {
      allow read, write: if request.auth != null
                         && request.auth.token.email == userEmail;
    }
  }
}
