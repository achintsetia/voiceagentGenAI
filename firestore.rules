rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can read and write only their own conversation sessions.
    // Path: /conversations/{userEmail}/sessions/{sessionId}
    match /conversations/{userEmail}/sessions/{sessionId} {
      allow read, write: if request.auth != null
                         && request.auth.token.email == userEmail;
    }
  }
}
